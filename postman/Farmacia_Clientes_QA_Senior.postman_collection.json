            "body": {
              "mode": "raw",
              "raw": "{\n  \"ativo\": false\n}"
            },
            "url": "{{baseUrl}}/api/v1/clientes/{{e2eClienteId}}"
          }
        },
        {
          "name": "E2E-06: Confirmar estado final",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E-06] Estado final: 200 OK', () => pm.response.to.have.status(200));",

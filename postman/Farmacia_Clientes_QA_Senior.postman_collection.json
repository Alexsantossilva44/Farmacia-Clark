                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"estoquista@farmacia.com\",\n  \"senha\": \"est123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/token"
          }
        },
        {
          "name": "Login — Credenciais Inválidas → 401",
          "event": [

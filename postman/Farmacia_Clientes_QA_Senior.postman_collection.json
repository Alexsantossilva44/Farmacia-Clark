    {
      "name": "01 — POST Clientes (Cadastro)",
      "description": "Testa o endpoint POST /api/v1/clientes com cenários positivos e negativos.",
      "item": [
        {
          "name": "CT-01: Cadastro válido → 201 (Happy Path)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Gera CPF válido pelo algoritmo de módulo 11",
                  "function gerarCpfValido() {",
                  "  let d = Array.from({length: 9}, (_, i) => i === 0 ? Math.ceil(Math.random()*9) : Math.floor(Math.random()*10));",
                  "  let soma = d.reduce((acc, v, i) => acc + v * (10 - i), 0);",
                  "  let r = soma % 11; d.push(r < 2 ? 0 : 11 - r);",
                  "  soma = d.reduce((acc, v, i) => acc + v * (11 - i), 0);",
                  "  r = soma % 11; d.push(r < 2 ? 0 : 11 - r);",
                  "  return d.join('');",
                  "}",
                  "const cpf = gerarCpfValido();",
                  "pm.collectionVariables.set('clienteCpf', cpf);",
                  "pm.variables.set('cpfDinamico', cpf);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Retorna ID (UUID)', () => {",
                  "  pm.expect(body.id).to.be.a('string');",
                  "  pm.expect(body.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
                  "});",
                  "pm.test('Nome correto', () => pm.expect(body.nome).to.eql('Maria Silva'));",
                  "pm.test('CPF persistido', () => pm.expect(body.cpf).to.eql(pm.collectionVariables.get('clienteCpf')));",
                  "pm.test('Cliente ativo por padrão', () => pm.expect(body.ativo).to.be.true);",
                  "pm.collectionVariables.set('clienteId', body.id);",
                  "console.log('Cliente criado:', body.id, '| CPF:', body.cpf);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Silva\",\n  \"cpf\": \"{{cpfDinamico}}\",\n  \"dataNascimento\": \"1990-06-15\",\n  \"sexo\": \"FEMININO\",\n  \"telefone\": \"11912345678\",\n  \"email\": \"maria.silva@teste.com\",\n  \"alergias\": \"Penicilina\",\n  \"observacoes\": \"Teste via Postman\",\n  \"endereco\": {\n    \"logradouro\": \"Rua das Palmeiras\",\n    \"numero\": \"42\",\n    \"bairro\": \"Jardim Europa\",\n    \"cidade\": \"São Paulo\",\n    \"uf\": \"SP\",\n    \"cep\": \"01310100\"\n  }\n}"
            },
            "url": "{{baseUrl}}/api/v1/clientes"
          }
        },
        {
          "name": "CT-02: Balconista pode cadastrar → 201",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function gerarCpfValido() {",
                  "  let d = Array.from({length: 9}, (_, i) => i === 0 ? Math.ceil(Math.random()*9) : Math.floor(Math.random()*10));",
                  "  let soma = d.reduce((acc, v, i) => acc + v * (10 - i), 0);",
                  "  let r = soma % 11; d.push(r < 2 ? 0 : 11 - r);",
                  "  soma = d.reduce((acc, v, i) => acc + v * (11 - i), 0);",

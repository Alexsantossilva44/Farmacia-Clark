                  "  pm.expect(pm.response.json().nome).to.eql('João E2E da Silva Atualizado');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João E2E da Silva Atualizado\",\n  \"alergias\": \"Nenhuma conhecida\"\n}"

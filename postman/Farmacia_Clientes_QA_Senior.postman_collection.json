    {
      "name": "06 — Fluxo E2E Completo",
      "description": "Executa o ciclo completo de vida do cliente: Cadastrar → Buscar → Atualizar → Inativar → Verificar. Todos os requests estão encadeados via pm.variables locais.",
      "item": [
        {
          "name": "E2E-01: Cadastrar cliente fresco",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function gerarCpfValido() {",
                  "  let d = Array.from({length: 9}, (_, i) => i === 0 ? Math.ceil(Math.random()*9) : Math.floor(Math.random()*10));",
                  "  let soma = d.reduce((acc, v, i) => acc + v * (10 - i), 0);",
                  "  let r = soma % 11; d.push(r < 2 ? 0 : 11 - r);",
                  "  soma = d.reduce((acc, v, i) => acc + v * (11 - i), 0);",
                  "  r = soma % 11; d.push(r < 2 ? 0 : 11 - r);",
                  "  return d.join('');",
                  "}",
                  "pm.variables.set('e2eCpf', gerarCpfValido());",
                  "pm.variables.set('e2eEmail', 'e2e.' + Date.now() + '@qa.com');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E-01] Cadastro: 201 Created', () => pm.response.to.have.status(201));",
                  "pm.variables.set('e2eClienteId', pm.response.json().id);",
                  "console.log('[E2E] clienteId:', pm.variables.get('e2eClienteId'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João E2E Silva\",\n  \"cpf\": \"{{e2eCpf}}\",\n  \"dataNascimento\": \"1988-04-10\",\n  \"telefone\": \"11988880001\",\n  \"email\": \"{{e2eEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/clientes"
          }
        },
        {
          "name": "E2E-02: Buscar por CPF",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E-02] Busca por CPF: 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('[E2E-02] ID bate com cadastrado', () => {",
                  "  pm.expect(pm.response.json().id).to.eql(pm.variables.get('e2eClienteId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/api/v1/clientes/cpf/{{e2eCpf}}"
          }
        },
        {
          "name": "E2E-03: Buscar por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E-03] Busca por ID: 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('[E2E-03] Nome é João E2E Silva', () => {",
                  "  pm.expect(pm.response.json().nome).to.eql('João E2E Silva');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/api/v1/clientes/{{e2eClienteId}}"
          }
        },
        {
          "name": "E2E-04: Atualizar dados",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E-04] Atualização: 200 OK', () => pm.response.to.have.status(200));",

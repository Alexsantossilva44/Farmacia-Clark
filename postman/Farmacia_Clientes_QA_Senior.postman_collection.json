                  "pm.test('[E2E-06] cliente inativo', () => pm.expect(body.ativo).to.be.false);",
                  "pm.test('[E2E-06] nome final correto', () => pm.expect(body.nome).to.eql('João E2E da Silva Atualizado'));",
                  "console.log('=== Fluxo E2E concluído com sucesso ===');",
                  "console.log('ID:', body.id, '| Nome:', body.nome, '| Ativo:', body.ativo);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/api/v1/clientes/{{e2eClienteId}}"
          }
        }
      ]
    }

